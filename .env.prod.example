# Copy to .env.prod and fill in real values, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# Never commit .env.prod - it holds production database credentials.

# DNS A/AAAA records for both of these must already point at this VPS -
# Caddy requests Let's Encrypt certificates for them on first request.
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com

# Consumed by the mysql service only - the backend container gets its own
# DB_DATABASE/DB_USERNAME/DB_PASSWORD from backend/.env (keep the two in
# sync manually; they intentionally aren't the same file).
DB_DATABASE=khadmatona
DB_USERNAME=khadmatona
DB_PASSWORD=change-me-generate-a-real-password
DB_ROOT_PASSWORD=change-me-generate-a-different-real-password
