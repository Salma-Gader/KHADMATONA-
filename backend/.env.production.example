# Production template for backend/.env - copy it there and fill in real
# values. Differs from .env.example (local Sail dev) in the fields called
# out below; everything else (Redis/queue/cache driver choices, Cloudinary
# as the media disk) is already correct for production as shipped.
#
#   cp backend/.env.production.example backend/.env
#   docker compose -f docker-compose.prod.yml exec backend php artisan key:generate --force

APP_NAME=KHADMATONA
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Real API domain (matches API_DOMAIN in the root .env.prod / Caddyfile).
APP_URL=https://api.example.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
SUPPORTED_LOCALES=ar,fr,en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# DB_HOST stays the docker-compose service name, same as local dev - only
# the credentials change, and they must match the root .env.prod's
# DB_DATABASE/DB_USERNAME/DB_PASSWORD used to provision the mysql container.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=khadmatona
DB_USERNAME=khadmatona
DB_PASSWORD=change-me-match-root-env-prod

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Real apex/parent domain shared by both subdomains, so the Sanctum session
# cookie set by the API is readable by the frontend on APP_DOMAIN.
SESSION_DOMAIN=.example.com

# Real frontend domain (APP_DOMAIN) - without both listed here, Sanctum
# rejects the SPA's cookie-based auth requests as cross-site.
SANCTUM_STATEFUL_DOMAINS=app.example.com
FRONTEND_URL=https://app.example.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

MEDIA_DISK=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Real transactional mail provider credentials - Mailpit only exists in the
# local dev compose.yaml, there is no mailpit service in docker-compose.prod.yml.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
